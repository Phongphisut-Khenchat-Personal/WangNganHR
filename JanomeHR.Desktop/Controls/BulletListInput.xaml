<UserControl x:Class="JanomeHR.Desktop.Controls.BulletListInput"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:JanomeHR.Desktop.Controls">

    <StackPanel>
        <TextBlock x:Name="LblCaption"
                   Style="{StaticResource LabelCaption}"
                   Margin="0,0,0,8"/>
        <StackPanel x:Name="ItemsPanel"/>
        <Button x:Name="BtnAdd" Margin="0,8,0,0" HorizontalAlignment="Left"
                Background="#F4F4F2" Foreground="#1A1A1A"
                BorderBrush="#E0DEDD" BorderThickness="1"
                Padding="10,6" Cursor="Hand" Click="BtnAdd_Click">
            <controls:FaButtonContent x:Name="BtnAddContent" Icon="plus" Label="+"
                IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
        </Button>
    </StackPanel>
</UserControl>
