<Page x:Class="JanomeHR.Desktop.Views.Pages.JobPostingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:JanomeHR.Desktop.Controls"
      Background="#F4F4F2"
      FontFamily="{StaticResource AppFont}"
      FontSize="{StaticResource FontSizeMin}">



    <Grid Margin="24">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>



        <DockPanel Grid.Row="0" Margin="0,0,0,12">

            <Button DockPanel.Dock="Right"

                    Style="{StaticResource PrimaryButton}"

                    Click="BtnCreate_Click">

                <controls:FaButtonContent Icon="plus" Label="{DynamicResource Btn_CreateJob}"

                    IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

            </Button>

            <Button DockPanel.Dock="Right"

                    Style="{StaticResource DarkButton}"

                    Margin="0,0,8,0"

                    Click="BtnRefresh_Click">

                <controls:FaButtonContent Icon="rotate" Label="{DynamicResource Btn_Refresh}"

                    IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

            </Button>

            <TextBlock Text="" VerticalAlignment="Center"/>

        </DockPanel>



        <ScrollViewer Grid.Row="1">

            <ItemsControl x:Name="LstJobs">

                <ItemsControl.ItemTemplate>

                    <DataTemplate>

                        <Border Background="White" CornerRadius="6"

                                BorderBrush="#E0DEDD" BorderThickness="1"

                                Padding="20,16" Margin="0,0,0,10">

                            <Grid VerticalAlignment="Center">

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="*"/>

                                    <ColumnDefinition Width="Auto"/>

                                </Grid.ColumnDefinitions>



                                <StackPanel Grid.Column="0" VerticalAlignment="Center">

                                    <DockPanel Margin="0,0,0,6">

                                        <Border Background="{Binding StatusColor}"

                                                CornerRadius="12" Padding="14,8" MinHeight="36"

                                                HorizontalAlignment="Left" Margin="0,0,8,0"

                                                VerticalAlignment="Center">

                                            <TextBlock Text="{Binding StatusText}"

                                                       Style="{StaticResource BadgeText}"

                                                       VerticalAlignment="Center"

                                                       Foreground="{Binding StatusTextColor}"/>

                                        </Border>

                                        <TextBlock Text="{Binding DepartmentName}"

                                                   Style="{StaticResource TableCellMuted}"

                                                   VerticalAlignment="Center"/>

                                    </DockPanel>

                                    <TextBlock Text="{Binding Title}"

                                               FontWeight="SemiBold"

                                               Margin="0,0,0,4"/>

                                    <TextBlock Text="{Binding SalaryText}"

                                               Foreground="#C8102E"

                                               FontWeight="SemiBold" Margin="0,0,0,4"/>

                                    <TextBlock Text="{Binding Meta}"

                                               Style="{StaticResource TableCellMuted}"/>

                                </StackPanel>



                                <StackPanel Grid.Column="1"

                                            Orientation="Horizontal"

                                            VerticalAlignment="Center">

                                    <Button Tag="{Binding Id}"

                                            Background="#C8102E" Foreground="White"

                                            BorderThickness="0" Cursor="Hand"

                                            Margin="0,0,6,0"

                                            Visibility="{Binding EditVisible}"

                                            Click="BtnEdit_Click">

                                        <controls:FaButtonContent Icon="gear" Label="{DynamicResource Btn_Edit}"

                                            IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                                    </Button>

                                    <Button Tag="{Binding Id}"

                                            Background="#1A7A4A" Foreground="White"

                                            BorderThickness="0" Cursor="Hand"

                                            Margin="0,0,6,0"

                                            Visibility="{Binding PublishVisible}"

                                            Click="BtnPublish_Click">

                                        <controls:FaButtonContent Icon="bullhorn" Label="{DynamicResource Btn_Publish}"

                                            IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                                    </Button>

                                    <Button Tag="{Binding Id}"

                                            Background="#6B6B6B" Foreground="White"

                                            BorderThickness="0" Cursor="Hand"

                                            Margin="0,0,6,0"

                                            Visibility="{Binding CloseVisible}"

                                            Click="BtnClose_Click">

                                        <controls:FaButtonContent Icon="lock" Label="{DynamicResource Btn_ClosePosting}"

                                            IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                                    </Button>

                                    <Button Tag="{Binding Id}"

                                            Background="#1D4ED8" Foreground="White"

                                            BorderThickness="0" Cursor="Hand"

                                            Visibility="{Binding QrVisible}"

                                            Click="BtnQr_Click">

                                        <controls:FaButtonContent Icon="qrcode" Label="{DynamicResource Btn_QrCode}"

                                            IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                                    </Button>

                                </StackPanel>

                            </Grid>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </ScrollViewer>

    </Grid>

</Page>