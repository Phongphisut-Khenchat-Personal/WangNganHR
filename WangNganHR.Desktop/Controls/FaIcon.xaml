<UserControl x:Class="WangNganHR.Desktop.Controls.FaIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             x:Name="Root"
             Width="20" Height="20">
    <iconPacks:PackIconFontAwesome x:Name="PART_Icon"
                                   Width="{Binding Width, ElementName=Root}"
                                   Height="{Binding Height, ElementName=Root}"
                                   Foreground="{Binding IconBrush, ElementName=Root}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
</UserControl>
