<Page x:Class="WangNganHR.Desktop.Views.Pages.InterviewsPage"

      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

      xmlns:controls="clr-namespace:WangNganHR.Desktop.Controls"

      Background="#F4F4F2"

      FontFamily="{StaticResource AppFont}"

      FontSize="{StaticResource FontSizeMin}">



    <Grid Margin="24">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>



        <!-- Date Navigator -->

        <Border Grid.Row="0" Background="White" CornerRadius="6"

                BorderBrush="#E0DEDD" BorderThickness="1"

                Padding="16,12" Margin="0,0,0,12">

            <DockPanel LastChildFill="True">

                <Button DockPanel.Dock="Left"

                        Width="44" Height="44" MinWidth="44" MinHeight="44"

                        Padding="0" Margin="0,0,8,0"

                        Background="White" BorderBrush="#E0DEDD" BorderThickness="1.5"

                        Cursor="Hand"

                        Click="BtnPrevDay_Click">

                    <Button.ToolTip>

                        <TextBlock Text="{DynamicResource Interview_PrevDay}"/>

                    </Button.ToolTip>

                    <controls:FaIcon Icon="chevron-left" IconBrush="#1A1A1A" Width="16" Height="16"/>

                </Button>



                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">

                    <Button x:Name="BtnToday"

                            Content="{DynamicResource Interview_Today}"

                            MinHeight="44" Padding="16,0" Margin="0,0,8,0"

                            Background="#1A1A1A" Foreground="White"

                            BorderThickness="0" Cursor="Hand"

                            Click="BtnToday_Click"/>

                    <Button Width="44" Height="44" MinWidth="44" MinHeight="44"

                            Padding="0"

                            Background="White" BorderBrush="#E0DEDD" BorderThickness="1.5"

                            Cursor="Hand"

                            Click="BtnNextDay_Click">

                        <Button.ToolTip>

                            <TextBlock Text="{DynamicResource Interview_NextDay}"/>

                        </Button.ToolTip>

                        <controls:FaIcon Icon="chevron-right" IconBrush="#1A1A1A" Width="16" Height="16"/>

                    </Button>

                </StackPanel>



                <TextBlock x:Name="TxtDate"

                           HorizontalAlignment="Center"

                           VerticalAlignment="Center"

                           FontSize="{StaticResource FontSizeHeading}"

                           FontWeight="SemiBold"/>

            </DockPanel>

        </Border>



        <!-- Stats -->

        <Grid Grid.Row="1" Margin="0,0,0,12">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="*"/>

            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="6"

                    BorderBrush="#E0DEDD" BorderThickness="1"

                    Margin="0,0,8,0" Padding="14,10">

                <StackPanel>

                    <TextBlock x:Name="TxtTotalToday" Text="0"

                               FontSize="{StaticResource FontSizeStat}" FontWeight="SemiBold"

                               Foreground="#1D4ED8"/>

                    <TextBlock Text="{DynamicResource Stat_TotalToday}" Style="{StaticResource StatCaption}"/>

                </StackPanel>

            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="6"

                    BorderBrush="#E0DEDD" BorderThickness="1"

                    Margin="0,0,8,0" Padding="14,10">

                <StackPanel>

                    <TextBlock x:Name="TxtOnline" Text="0"

                               FontSize="{StaticResource FontSizeStat}" FontWeight="SemiBold"

                               Foreground="#1A7A4A"/>

                    <TextBlock Text="{DynamicResource Stat_Online}" Style="{StaticResource StatCaption}"/>

                </StackPanel>

            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="6"

                    BorderBrush="#E0DEDD" BorderThickness="1"

                    Padding="14,10">

                <StackPanel>

                    <TextBlock x:Name="TxtOnsite" Text="0"

                               FontSize="{StaticResource FontSizeStat}" FontWeight="SemiBold"

                               Foreground="#B45309"/>

                    <TextBlock Text="{DynamicResource Stat_Onsite}" Style="{StaticResource StatCaption}"/>

                </StackPanel>

            </Border>

        </Grid>



        <!-- Interview List -->

        <Border Grid.Row="2" Background="White" CornerRadius="6"

                BorderBrush="#E0DEDD" BorderThickness="1">

            <Grid>

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="*"/>

                </Grid.RowDefinitions>



                <!-- Table Header -->

                <Border Grid.Row="0" Background="#F4F4F2"

                        BorderBrush="#E0DEDD" BorderThickness="0,0,0,1"

                        Padding="24,16" MinHeight="52">

                    <Grid VerticalAlignment="Center">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="100"/>

                            <ColumnDefinition Width="170"/>

                            <ColumnDefinition Width="1.4*"/>

                            <ColumnDefinition Width="130"/>

                            <ColumnDefinition Width="100"/>

                            <ColumnDefinition Width="120"/>

                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="HdrTime" Grid.Column="0" Style="{StaticResource TableHeaderLabel}"/>

                        <TextBlock x:Name="HdrApplicant" Grid.Column="1" Style="{StaticResource TableHeaderLabel}"/>

                        <TextBlock x:Name="HdrJob" Grid.Column="2" Style="{StaticResource TableHeaderLabel}"/>

                        <TextBlock x:Name="HdrInterviewer" Grid.Column="3" Style="{StaticResource TableHeaderLabel}"/>

                        <TextBlock x:Name="HdrType" Grid.Column="4" Style="{StaticResource TableHeaderLabel}"/>

                        <TextBlock x:Name="HdrStatus" Grid.Column="5" Style="{StaticResource TableHeaderLabel}"/>

                    </Grid>

                </Border>



                <!-- Rows -->

                <ScrollViewer Grid.Row="1">

                    <ItemsControl x:Name="LstInterviews">

                        <ItemsControl.ItemTemplate>

                            <DataTemplate>

                                <Border BorderBrush="#F0EEEB"

                                        BorderThickness="0,0,0,1"

                                        Padding="24,16" MinHeight="52">

                                    <Grid VerticalAlignment="Center">

                                        <Grid.ColumnDefinitions>

                                            <ColumnDefinition Width="100"/>

                                            <ColumnDefinition Width="170"/>

                                            <ColumnDefinition Width="1.4*"/>

                                            <ColumnDefinition Width="130"/>

                                            <ColumnDefinition Width="100"/>

                                            <ColumnDefinition Width="120"/>

                                        </Grid.ColumnDefinitions>



                                        <TextBlock Grid.Column="0"

                                                   Text="{Binding TimeText}"

                                                   Style="{StaticResource TableCellText}"

                                                   FontWeight="SemiBold"

                                                   Foreground="#C8102E"/>

                                        <StackPanel Grid.Column="1"

                                                    VerticalAlignment="Center">

                                            <TextBlock Text="{Binding ApplicantName}"

                                                       Style="{StaticResource TableCellText}"

                                                       FontWeight="SemiBold"/>

                                            <TextBlock Text="{Binding DurationText}"

                                                       Style="{StaticResource TableCellMuted}"/>

                                        </StackPanel>

                                        <TextBlock Grid.Column="2"

                                                   Text="{Binding JobPostingTitle}"

                                                   Style="{StaticResource TableCellText}"

                                                   Foreground="#555"

                                                   TextWrapping="Wrap"/>

                                        <TextBlock Grid.Column="3"

                                                   Text="{Binding InterviewerName}"

                                                   Style="{StaticResource TableCellText}"

                                                   Foreground="#555"/>

                                        <Border Grid.Column="4"

                                                Background="{Binding TypeColor}"

                                                CornerRadius="12" Padding="14,8" MinHeight="36"

                                                HorizontalAlignment="Left"

                                                VerticalAlignment="Center">

                                            <TextBlock Text="{Binding TypeText}"

                                                       Style="{StaticResource BadgeText}"

                                                       VerticalAlignment="Center"

                                                       Foreground="{Binding TypeTextColor}"/>

                                        </Border>

                                        <Border Grid.Column="5"

                                                Background="{Binding StatusColor}"

                                                CornerRadius="12" Padding="14,8" MinHeight="36"

                                                HorizontalAlignment="Left"

                                                VerticalAlignment="Center">

                                            <TextBlock Text="{Binding StatusText}"

                                                       Style="{StaticResource BadgeText}"

                                                       VerticalAlignment="Center"

                                                       Foreground="{Binding StatusTextColor}"/>

                                        </Border>

                                    </Grid>

                                </Border>

                            </DataTemplate>

                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </ScrollViewer>



                <!-- Empty State -->

                <TextBlock x:Name="TxtEmpty"

                           Grid.Row="1"

                           Text="{DynamicResource Interview_Empty}"

                           HorizontalAlignment="Center"

                           VerticalAlignment="Center"

                           Foreground="#6B6B6B"

                           Margin="0,40"/>

            </Grid>

        </Border>

    </Grid>

</Page>

