<Page x:Class="JanomeHR.Desktop.Views.Pages.ApplicationsPage"

      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

      xmlns:controls="clr-namespace:JanomeHR.Desktop.Controls"

      Background="#F4F4F2"

      FontFamily="{StaticResource AppFont}"

      FontSize="{StaticResource FontSizeMin}">

    <Page.Resources>
        <Style x:Key="CellPhoneStyle" TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextNoTrim}">
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>
    </Page.Resources>

    <Grid Margin="24">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>



        <Grid Grid.Row="0" Margin="0,0,0,20">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="*"/>

            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8"

                    BorderBrush="#E0DEDD" BorderThickness="1" Margin="0,0,10,0" Padding="18,16">

                <StackPanel>

                    <TextBlock x:Name="TxtTotalNew" Text="0"

                               FontSize="{StaticResource FontSizeStat}"

                               FontWeight="SemiBold" Foreground="#C8102E"/>

                    <TextBlock Text="{DynamicResource Stat_NewToday}" Foreground="#6B6B6B" Margin="0,4,0,0"/>

                </StackPanel>

            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8"

                    BorderBrush="#E0DEDD" BorderThickness="1" Margin="0,0,10,0" Padding="18,16">

                <StackPanel>

                    <TextBlock x:Name="TxtTotalReview" Text="0"

                               FontSize="{StaticResource FontSizeStat}"

                               FontWeight="SemiBold" Foreground="#B45309"/>

                    <TextBlock Text="{DynamicResource Stat_Review}" Foreground="#6B6B6B" Margin="0,4,0,0"/>

                </StackPanel>

            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="8"

                    BorderBrush="#E0DEDD" BorderThickness="1" Margin="0,0,10,0" Padding="18,16">

                <StackPanel>

                    <TextBlock x:Name="TxtTotalInterview" Text="0"

                               FontSize="{StaticResource FontSizeStat}"

                               FontWeight="SemiBold" Foreground="#1D4ED8"/>

                    <TextBlock Text="{DynamicResource Stat_Interview}" Foreground="#6B6B6B" Margin="0,4,0,0"/>

                </StackPanel>

            </Border>

            <Border Grid.Column="3" Background="White" CornerRadius="8"

                    BorderBrush="#E0DEDD" BorderThickness="1" Padding="18,16">

                <StackPanel>

                    <TextBlock x:Name="TxtTotalPass" Text="0"

                               FontSize="{StaticResource FontSizeStat}"

                               FontWeight="SemiBold" Foreground="#1A7A4A"/>

                    <TextBlock Text="{DynamicResource Stat_Pass}" Foreground="#6B6B6B" Margin="0,4,0,0"/>

                </StackPanel>

            </Border>

        </Grid>



        <Grid Grid.Row="1" Margin="0,0,0,16">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="200"/>

                <ColumnDefinition Width="200"/>

                <ColumnDefinition Width="180"/>

                <ColumnDefinition Width="Auto"/>

            </Grid.ColumnDefinitions>

            <TextBox x:Name="TxtSearch"

                     Grid.Column="0"

                     Margin="0,0,12,0"

                     controls:PlaceholderProperties.Text="{DynamicResource Placeholder_Search}"

                     TextChanged="TxtSearch_TextChanged"/>

            <ComboBox x:Name="CmbJob" Grid.Column="1"

                      Margin="0,0,12,0"

                      SelectionChanged="CmbFilter_Changed"/>

            <ComboBox x:Name="CmbStatus" Grid.Column="2"

                      Margin="0,0,12,0"

                      SelectionChanged="CmbFilter_Changed"/>

            <ComboBox x:Name="CmbDate" Grid.Column="3"

                      Margin="0,0,12,0"

                      SelectionChanged="CmbFilter_Changed"/>

            <Button Grid.Column="4" Style="{StaticResource DarkButton}"

                    Click="BtnRefresh_Click">

                <controls:FaButtonContent Icon="rotate" Label="{DynamicResource Btn_Refresh}"

                    IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

            </Button>

        </Grid>



        <Border Grid.Row="2" Background="White" CornerRadius="8"

                BorderBrush="#E0DEDD" BorderThickness="1"

                Padding="4,0,4,0" ClipToBounds="True">

            <DataGrid x:Name="DgApplications"

                      AutoGenerateColumns="False"

                      IsReadOnly="True"

                      GridLinesVisibility="None"

                      HeadersVisibility="Column"

                      Background="White"

                      BorderThickness="0"

                      SelectionMode="Single"

                      HorizontalScrollBarVisibility="Auto"

                      MouseDoubleClick="DgApplications_DoubleClick"

                      AlternatingRowBackground="#FAFAF8">

                <DataGrid.Columns>

                    <DataGridTextColumn x:Name="ColReference" Header="รหัส"

                                        Binding="{Binding ReferenceCode}"

                                        Width="155" MinWidth="145"

                                        ElementStyle="{StaticResource DataGridCellTextNoTrim}"/>

                    <DataGridTextColumn x:Name="ColFullName" Header="ชื่อ-นามสกุล"

                                        Binding="{Binding FullName}"

                                        Width="220" MinWidth="170"

                                        ElementStyle="{StaticResource DataGridCellTextStyle}"/>

                    <DataGridTextColumn x:Name="ColJob" Header="ตำแหน่ง"

                                        Binding="{Binding JobPostingTitle}"

                                        Width="240" MinWidth="185"

                                        ElementStyle="{StaticResource DataGridCellTextStyle}"/>

                    <DataGridTextColumn x:Name="ColPhone" Header="เบอร์โทร"

                                        Binding="{Binding Phone}"

                                        Width="148" MinWidth="135"

                                        ElementStyle="{StaticResource CellPhoneStyle}"/>

                    <DataGridTextColumn x:Name="ColSource" Header="ช่องทาง"

                                        Binding="{Binding SourceText}"

                                        Width="92" MinWidth="82"

                                        ElementStyle="{StaticResource DataGridCellTextStyle}"/>

                    <DataGridTemplateColumn x:Name="ColStatus" Header="สถานะ"

                                            Width="168" MinWidth="150">

                        <DataGridTemplateColumn.CellTemplate>

                            <DataTemplate>

                                <Border CornerRadius="12"

                                        Background="{Binding StatusColor}"

                                        Padding="12,6" MinHeight="32"

                                        HorizontalAlignment="Left"

                                        VerticalAlignment="Center">

                                    <TextBlock Text="{Binding StatusText}"

                                               Style="{StaticResource BadgeText}"

                                               VerticalAlignment="Center"

                                               Foreground="{Binding StatusTextColor}"/>

                                </Border>

                            </DataTemplate>

                        </DataGridTemplateColumn.CellTemplate>

                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn x:Name="ColCreatedAt" Header="วันที่สมัคร"

                                            Width="128" MinWidth="116">

                        <DataGridTemplateColumn.CellTemplate>

                            <DataTemplate>

                                <StackPanel VerticalAlignment="Center">

                                    <TextBlock Text="{Binding CreatedAtDate}"

                                               Style="{StaticResource DataGridCellTextNoTrim}"

                                               TextWrapping="NoWrap"/>

                                    <TextBlock Text="{Binding CreatedAtTime}"

                                               Style="{StaticResource DataGridCellTextNoTrim}"

                                               TextWrapping="NoWrap"

                                               Margin="0,2,0,0"/>

                                </StackPanel>

                            </DataTemplate>

                        </DataGridTemplateColumn.CellTemplate>

                    </DataGridTemplateColumn>

                </DataGrid.Columns>

            </DataGrid>

        </Border>



        <TextBlock Grid.Row="3" x:Name="TxtCount"

                   Foreground="#6B6B6B" Margin="0,12,0,0"/>

    </Grid>

</Page>

