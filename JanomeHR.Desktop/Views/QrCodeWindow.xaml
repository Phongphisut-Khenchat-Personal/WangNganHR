<Window x:Class="JanomeHR.Desktop.Views.QrCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QR Code สำหรับสมัครงาน"
        Height="420" Width="360"
        WindowStartupLocation="CenterOwner"
        Background="#F4F4F2" ResizeMode="NoResize">
    <StackPanel Margin="32">
        <Border Background="#1A1A1A" Padding="16,12" Margin="0,0,0,20">
            <TextBlock Text="QR Code สมัครงาน"
                       Foreground="White" FontSize="16"
                       FontWeight="SemiBold" HorizontalAlignment="Center"/>
        </Border>

        <Border Background="White" Padding="16"
                BorderBrush="#E0DEDD" BorderThickness="1"
                HorizontalAlignment="Center" Margin="0,0,0,20">
            <Image x:Name="ImgQr" Width="240" Height="240"
                   Stretch="Uniform"/>
        </Border>

        <TextBlock Text="พิมพ์และติดที่ป้อมยาม" FontSize="13"
                   Foreground="#888" HorizontalAlignment="Center"
                   Margin="0,0,0,16"/>

        <Button Content="พิมพ์ / บันทึก"
                Padding="16,10" FontSize="14"
                Background="#C8102E" Foreground="White"
                BorderThickness="0" Cursor="Hand"
                HorizontalAlignment="Stretch"
                Click="BtnPrint_Click"/>
    </StackPanel>
</Window>