<Window x:Class="JanomeHR.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Janome HR — เข้าสู่ระบบ"
        Height="520" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F4F4F2"
        FontFamily="{StaticResource AppFont}"
        FontSize="{StaticResource FontSizeMin}">

    <Grid>
        <Border Background="#1A1A1A" VerticalAlignment="Top" Height="150">
            <StackPanel VerticalAlignment="Center" Margin="36,0">
                <Border Background="#C8102E" HorizontalAlignment="Left"
                        Padding="12,6" Margin="0,0,0,10">
                    <TextBlock Text="JANOME" Foreground="White"
                               FontSize="{StaticResource FontSizeMin}" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="HR Recruitment System"
                           Foreground="#AAAAAA"/>
                <TextBlock Text="เข้าสู่ระบบ"
                           Foreground="White" FontSize="{StaticResource FontSizeTitle}"
                           FontWeight="SemiBold" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Margin="36,170,36,0" VerticalAlignment="Top">

            <TextBlock Text="ชื่อผู้ใช้" Style="{StaticResource LabelCaption}" Margin="0,0,0,8"/>
            <TextBox x:Name="TxtUsername" KeyDown="OnKeyDown"/>

            <TextBlock Text="รหัสผ่าน" Style="{StaticResource LabelCaption}"
                       Margin="0,20,0,8"/>
            <PasswordBox x:Name="TxtPassword" KeyDown="OnKeyDown"/>

            <TextBlock x:Name="TxtError"
                       Foreground="#C8102E"
                       Margin="0,16,0,0" Visibility="Collapsed"
                       TextWrapping="Wrap"/>

            <Button x:Name="BtnLogin"
                    Content="เข้าสู่ระบบ"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,24,0,0"
                    Click="BtnLogin_Click"/>

        </StackPanel>

        <TextBlock Text="Janome Thailand HR System v1.0"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                   Margin="0,0,0,24" Foreground="#888888"/>
    </Grid>
</Window>
