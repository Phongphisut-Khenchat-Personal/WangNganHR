<Window x:Class="WangNganHR.Desktop.Views.MainWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:controls="clr-namespace:WangNganHR.Desktop.Controls"

        Title="{DynamicResource Window_Dashboard}"

        Height="720" Width="1140"

        WindowStartupLocation="CenterScreen"

        Background="#F4F4F2"

        FontFamily="{StaticResource AppFont}"

        FontSize="{StaticResource FontSizeMin}">



    <Grid>

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="240"/>

            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>



        <Border Grid.Column="0" Background="#1A1A1A">

            <DockPanel>

                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,20">

                    <Border Background="#C8102E" HorizontalAlignment="Left"

                            Padding="12,6" Margin="0,0,0,8">

                        <TextBlock Text="{DynamicResource Brand_Mark}" Foreground="White" FontWeight="Bold"/>

                    </Border>

                    <TextBlock Text="{DynamicResource Brand_HR}" Foreground="#888888"/>

                    <TextBlock x:Name="TxtUsername"

                               Foreground="#CCCCCC"

                               Margin="0,12,0,0" TextWrapping="Wrap"/>

                </StackPanel>



                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,20">

                    <Button x:Name="BtnSettings"

                            Style="{StaticResource NavButton}"

                            Click="BtnSettings_Click">

                        <controls:FaButtonContent Icon="gear"

                            Label="{DynamicResource Btn_Settings}"

                            IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                        <Button.ContextMenu>

                            <ContextMenu x:Name="LanguageMenu"/>

                        </Button.ContextMenu>

                    </Button>

                    <TextBlock Text="{DynamicResource Footer_Version}"

                               Foreground="#666666"

                               Margin="20,14,20,0"

                               TextWrapping="Wrap"/>

                </StackPanel>



                <StackPanel Margin="0,8,0,0">

                    <Button x:Name="BtnApplications"

                            Style="{StaticResource NavButton}"

                            Tag="Applications"

                            Click="NavButton_Click">

                        <controls:FaButtonContent Icon="clipboard-list"

                            Label="{DynamicResource Nav_Applications}"

                            IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                    </Button>

                    <Button x:Name="BtnInterviews"

                            Style="{StaticResource NavButton}"

                            Tag="Interviews"

                            Click="NavButton_Click">

                        <controls:FaButtonContent Icon="calendar"

                            Label="{DynamicResource Nav_Interviews}"

                            IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                    </Button>

                    <Button x:Name="BtnJobPostings"

                            Style="{StaticResource NavButton}"

                            Tag="JobPostings"

                            Click="NavButton_Click">

                        <controls:FaButtonContent Icon="bullhorn"

                            Label="{DynamicResource Nav_JobPostings}"

                            IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                    </Button>

                </StackPanel>

            </DockPanel>

        </Border>



        <Grid Grid.Column="1">

            <Border Background="White" VerticalAlignment="Top" Height="56"

                    BorderBrush="#E0DEDD" BorderThickness="0,0,0,1">

                <DockPanel Margin="24,0">

                    <TextBlock x:Name="TxtPageTitle"

                               Text="{DynamicResource Page_Applications}"

                               FontSize="{StaticResource FontSizeHeading}"

                               FontWeight="SemiBold"

                               VerticalAlignment="Center"/>

                    <TextBlock x:Name="TxtBadge"

                               Foreground="White" FontWeight="Bold"

                               Background="#C8102E" Padding="10,4"

                               Margin="12,0,0,0" VerticalAlignment="Center"/>

                </DockPanel>

            </Border>



            <Frame x:Name="MainFrame"

                   Margin="0,56,0,0"

                   NavigationUIVisibility="Hidden"/>

        </Grid>

    </Grid>

</Window>
