<Window x:Class="JanomeHR.Desktop.Views.CreateJobPostingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="สร้างประกาศงานใหม่"
        Height="580" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="#F4F4F2">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A1A1A" Padding="24,16">
            <TextBlock Text="สร้างประกาศงานใหม่"
                       Foreground="White" FontSize="18" FontWeight="SemiBold"/>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="24,16">
            <StackPanel>
                <TextBlock Text="แผนก *" FontSize="11" FontWeight="SemiBold"
                           Foreground="#888" Margin="0,0,0,5"/>
                <ComboBox x:Name="CmbDept" Padding="10,8" FontSize="13"
                          Margin="0,0,0,14">
                    <ComboBoxItem Content="ฝ่ายผลิต"            Tag="1"/>
                    <ComboBoxItem Content="ฝ่ายควบคุมคุณภาพ"   Tag="2"/>
                    <ComboBoxItem Content="ฝ่าย Logistics"      Tag="3"/>
                    <ComboBoxItem Content="ฝ่ายซ่อมบำรุง"       Tag="4"/>
                    <ComboBoxItem Content="ฝ่าย HR"             Tag="5"/>
                    <ComboBoxItem Content="ฝ่ายธุรการ"          Tag="6"/>
                </ComboBox>

                <TextBlock Text="ชื่อตำแหน่ง *" FontSize="11" FontWeight="SemiBold"
                           Foreground="#888" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtTitle" Padding="10,8" FontSize="13"
                         BorderBrush="#E0DEDD" Background="White"
                         Margin="0,0,0,14"/>

                <TextBlock Text="รายละเอียดงาน *" FontSize="11" FontWeight="SemiBold"
                           Foreground="#888" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtDesc" Padding="10,8" FontSize="13"
                         BorderBrush="#E0DEDD" Background="White"
                         MinHeight="80" TextWrapping="Wrap" AcceptsReturn="True"
                         Margin="0,0,0,14"/>

                <TextBlock Text="คุณสมบัติ *" FontSize="11" FontWeight="SemiBold"
                           Foreground="#888" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtReq" Padding="10,8" FontSize="13"
                         BorderBrush="#E0DEDD" Background="White"
                         MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"
                         Margin="0,0,0,14"/>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="เงินเดือนต่ำสุด" FontSize="11"
                                   FontWeight="SemiBold" Foreground="#888" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtSalMin" Padding="10,8" FontSize="13"
                                 BorderBrush="#E0DEDD" Background="White"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <TextBlock Text="เงินเดือนสูงสุด" FontSize="11"
                                   FontWeight="SemiBold" Foreground="#888" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtSalMax" Padding="10,8" FontSize="13"
                                 BorderBrush="#E0DEDD" Background="White"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="จำนวนที่รับ" FontSize="11"
                                   FontWeight="SemiBold" Foreground="#888" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtCount" Padding="10,8" FontSize="13"
                                 BorderBrush="#E0DEDD" Background="White" Text="1"/>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="ChkPublishNow" Content="เผยแพร่ทันที"
                          FontSize="13" Margin="0,0,0,4"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White"
                BorderBrush="#E0DEDD" BorderThickness="0,1,0,0"
                Padding="24,12">
            <DockPanel>
                <Button Content="ยกเลิก" DockPanel.Dock="Right"
                        Padding="16,9" FontSize="13" Margin="8,0,0,0"
                        Background="#F4F4F2" Foreground="#1A1A1A"
                        BorderBrush="#E0DEDD" BorderThickness="1"
                        Cursor="Hand" Click="BtnCancel_Click"/>
                <Button Content="สร้างประกาศ" DockPanel.Dock="Right"
                        Padding="16,9" FontSize="13"
                        Background="#C8102E" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnSave_Click"/>
                <TextBlock x:Name="TxtError" Foreground="#C8102E"
                           FontSize="12" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>