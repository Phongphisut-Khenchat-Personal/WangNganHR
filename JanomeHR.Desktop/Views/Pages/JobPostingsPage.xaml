<Page x:Class="JanomeHR.Desktop.Views.Pages.JobPostingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F4F2">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <Button Content="+ สร้างประกาศงาน"
                    DockPanel.Dock="Right"
                    Padding="16,9" FontSize="13"
                    Background="#C8102E" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnCreate_Click"/>
            <Button Content="🔄 รีเฟรช"
                    DockPanel.Dock="Right"
                    Padding="14,9" FontSize="13" Margin="0,0,8,0"
                    Background="#1A1A1A" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnRefresh_Click"/>
            <TextBlock Text="" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- List -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="LstJobs">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="6"
                                BorderBrush="#E0DEDD" BorderThickness="1"
                                Padding="20,16" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <DockPanel Margin="0,0,0,4">
                                        <Border Background="{Binding StatusColor}"
                                                CornerRadius="10" Padding="8,2"
                                                HorizontalAlignment="Left" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding StatusText}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{Binding StatusTextColor}"/>
                                        </Border>
                                        <TextBlock Text="{Binding DepartmentName}"
                                                   FontSize="11" Foreground="#888"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="16" FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding SalaryText}"
                                               FontSize="13" Foreground="#C8102E"
                                               FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Meta}"
                                               FontSize="12" Foreground="#888"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Content="📢 Publish"
                                            Tag="{Binding Id}"
                                            Padding="10,7" FontSize="12"
                                            Background="#1A7A4A" Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            Margin="0,0,6,0"
                                            Visibility="{Binding PublishVisible}"
                                            Click="BtnPublish_Click"/>
                                    <Button Content="🔒 ปิดรับ"
                                            Tag="{Binding Id}"
                                            Padding="10,7" FontSize="12"
                                            Background="#6B6B6B" Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            Margin="0,0,6,0"
                                            Visibility="{Binding CloseVisible}"
                                            Click="BtnClose_Click"/>
                                    <Button Content="QR Code"
                                            Tag="{Binding Id}"
                                            Padding="10,7" FontSize="12"
                                            Background="#1D4ED8" Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            Visibility="{Binding QrVisible}"
                                            Click="BtnQr_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>