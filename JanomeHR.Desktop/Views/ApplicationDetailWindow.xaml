<Window x:Class="JanomeHR.Desktop.Views.ApplicationDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:JanomeHR.Desktop.Controls"
        Title="{DynamicResource Detail_Title}"
        Height="760" Width="820"
        MinHeight="640" MinWidth="720"
        WindowStartupLocation="CenterOwner"
        Background="#F4F4F2"
        FontFamily="{StaticResource AppFont}"
        FontSize="{StaticResource FontSizeMin}">

    <Window.Resources>
        <Style x:Key="DetailStepBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#E0DEDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F9FAFB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DetailStepBtnActive" TargetType="Button" BasedOn="{StaticResource DetailStepBtn}">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1A1A1A"/>
        </Style>
        <Style x:Key="PreviewSectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#C8102E"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeMin}"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1A1A1A" Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="TxtRefCode" Foreground="#C8102E" FontFamily="Consolas" FontSize="14"/>
                    <TextBlock x:Name="TxtName" Foreground="White" FontSize="{StaticResource FontSizeTitle}"
                               FontWeight="SemiBold" Margin="0,4,0,0"/>
                    <TextBlock x:Name="TxtPosition" Foreground="#AAAAAA" Margin="0,4,0,0"/>
                    <TextBlock x:Name="TxtDepartment" Foreground="#888888" FontSize="13" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" x:Name="BadgeStatus" Background="#374151" CornerRadius="6"
                        Padding="12,8" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtStatusBadge" Foreground="White" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <!-- Step bar -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0DEDD" BorderThickness="0,0,0,1" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnStepPreview" Grid.Column="0" Style="{StaticResource DetailStepBtnActive}"
                        Click="BtnStepPreview_Click" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="1" FontWeight="Bold" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource Detail_Step_Preview}"/>
                    </StackPanel>
                </Button>
                <Border Grid.Column="1" Width="40" Height="2" Background="#E0DEDD" VerticalAlignment="Center" Margin="8,0"/>
                <Button x:Name="BtnStepUpdate" Grid.Column="2" Style="{StaticResource DetailStepBtn}"
                        Click="BtnStepUpdate_Click" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="2" FontWeight="Bold" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource Detail_Step_Update}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" Padding="24,16" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- STEP 1: Preview -->
                <StackPanel x:Name="PnlPreview">
                    <ItemsControl x:Name="PreviewSections">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8"
                                        BorderBrush="#E0DEDD" BorderThickness="1"
                                        Padding="20" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource PreviewSectionTitle}"/>
                                        <ItemsControl ItemsSource="{Binding Fields}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="180"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Label}" Style="{StaticResource LabelCaption}"
                                                                   VerticalAlignment="Top" Margin="0,2,12,0"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Value}"
                                                                   TextWrapping="Wrap" FontWeight="Medium" LineHeight="22"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border x:Name="BorderWorkHistory" Background="White" CornerRadius="8" BorderBrush="#E0DEDD" BorderThickness="1"
                            Padding="20" Margin="0,0,0,14" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Detail_WorkHistory}" Style="{StaticResource PreviewSectionTitle}"/>
                            <ItemsControl x:Name="PreviewWorkHistory">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F9FAFB" CornerRadius="6" BorderBrush="#E5E7EB"
                                                BorderThickness="1" Padding="14" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <TextBlock Text="{Binding Subtitle}" Foreground="#6B6B6B" Margin="0,0,0,6"/>
                                                <TextBlock Text="{Binding Details}" TextWrapping="Wrap" LineHeight="22"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border x:Name="PnlDocuments" Background="White" CornerRadius="8"
                            BorderBrush="#E0DEDD" BorderThickness="1" Padding="20" Margin="0,0,0,14"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Detail_Documents}" Style="{StaticResource PreviewSectionTitle}"/>
                            <ItemsControl x:Name="PreviewDocuments">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#F0EEEB" BorderThickness="0,0,0,1" Padding="0,10">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Style="{StaticResource DarkButton}"
                                                        Padding="12,6" Margin="8,0,0,0"
                                                        Tag="{Binding Url}" Click="BtnOpenDocument_Click"
                                                        Content="{DynamicResource Detail_OpenDoc}"/>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding TypeLabel}" Foreground="#6B6B6B" FontSize="13" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- STEP 2: Update -->
                <StackPanel x:Name="PnlUpdate" Visibility="Collapsed">
                    <Border Background="White" CornerRadius="8" BorderBrush="#E0DEDD" BorderThickness="1"
                            Padding="20" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Detail_UpdateStatus}"
                                       FontWeight="SemiBold" Foreground="#C8102E" Margin="0,0,0,16"/>
                            <TextBlock Text="{DynamicResource Detail_NewStatus}"
                                       Style="{StaticResource LabelCaption}" Margin="0,0,0,8"/>
                            <ComboBox x:Name="CmbNewStatus" Margin="0,0,0,16"
                                      SelectionChanged="CmbNewStatus_SelectionChanged"/>

                            <Border x:Name="PnlInterview" Background="#EFF6FF" CornerRadius="6"
                                    BorderBrush="#BFDBFE" BorderThickness="1" Padding="16" Margin="0,0,0,16"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Detail_InterviewInfo}"
                                               FontWeight="SemiBold" Foreground="#1D4ED8" Margin="0,0,0,14"/>
                                    <TextBlock Text="{DynamicResource Detail_InterviewDate}"
                                               Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                                    <DatePicker x:Name="DpInterviewDate" BorderBrush="#BFDBFE" Background="White" Margin="0,0,0,14"/>
                                    <TextBlock Text="{DynamicResource Detail_Time}"
                                               Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="CmbHour" Grid.Column="0"/>
                                        <TextBlock Grid.Column="1" Text=":" FontSize="{StaticResource FontSizeHeading}"
                                                   FontWeight="Bold" VerticalAlignment="Center" Margin="8,0"/>
                                        <ComboBox x:Name="CmbMinute" Grid.Column="2"/>
                                        <TextBlock x:Name="LblDurationCaption" Grid.Column="3"
                                                   Text="{DynamicResource Detail_Duration}"
                                                   Style="{StaticResource LabelCaption}"
                                                   VerticalAlignment="Center" Margin="12,0,8,0"/>
                                        <ComboBox x:Name="CmbDuration" Grid.Column="4"/>
                                    </Grid>
                                    <TextBlock Text="{DynamicResource Detail_InterviewType}"
                                               Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="CmbInterviewType" Margin="0,0,0,14"
                                              SelectionChanged="CmbInterviewType_SelectionChanged"/>
                                    <TextBlock x:Name="LblLocation" Text="{DynamicResource Detail_Location}"
                                               Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtLocation" BorderBrush="#BFDBFE" Background="White"
                                             controls:PlaceholderProperties.Text="{DynamicResource Placeholder_Location}"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="{DynamicResource Detail_Note}"
                                       Style="{StaticResource LabelCaption}" Margin="0,0,0,8"/>
                            <TextBox x:Name="TxtNote" BorderBrush="#E0DEDD" MinHeight="88" TextWrapping="Wrap"
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                     controls:PlaceholderProperties.Text="{DynamicResource Placeholder_Note}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="8" BorderBrush="#E0DEDD" BorderThickness="1" Padding="20">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Detail_NoteHistory}"
                                       Style="{StaticResource LabelCaption}" Margin="0,0,0,16"/>
                            <ItemsControl x:Name="LstNotes">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#F0EEEB" BorderThickness="0,0,0,1" Padding="0,12">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,6">
                                                    <TextBlock Text="{Binding CreatedByName}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding CreatedAtText}" Foreground="#6B6B6B" DockPanel.Dock="Right"/>
                                                </DockPanel>
                                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap" LineHeight="24"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="TxtNoNotes" Text="{DynamicResource Detail_NoNotes}"
                                       Foreground="#9CA3AF" Visibility="Collapsed" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E0DEDD" BorderThickness="0,1,0,0" Padding="24,14">
            <DockPanel>
                <Button x:Name="BtnNext" DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                        Margin="8,0,0,0" Click="BtnNext_Click">
                    <controls:FaButtonContent Icon="chevron-right" Label="{DynamicResource Btn_Next}"
                        IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <Button x:Name="BtnSave" DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                        Margin="8,0,0,0" Visibility="Collapsed" Click="BtnSaveStatus_Click">
                    <controls:FaButtonContent Icon="save" Label="{DynamicResource Btn_Save}"
                        IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <Button x:Name="BtnBack" DockPanel.Dock="Right" Style="{StaticResource DarkButton}"
                        Margin="8,0,0,0" Visibility="Collapsed" Click="BtnBack_Click">
                    <controls:FaButtonContent Icon="chevron-left" Label="{DynamicResource Btn_Back}"
                        IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <Button DockPanel.Dock="Right" Style="{StaticResource DarkButton}" Click="BtnClose_Click">
                    <controls:FaButtonContent Icon="xmark" Label="{DynamicResource Btn_Close}"
                        IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
            </DockPanel>
        </Border>
    </Grid>
</Window>
