<Window x:Class="JanomeHR.Desktop.Views.CreateJobPostingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:JanomeHR.Desktop.Controls"
        Title="{DynamicResource CreateJob_Title}"
        Height="720" Width="640"
        MinHeight="640" MinWidth="580"
        WindowStartupLocation="CenterOwner"
        Background="#F4F4F2"
        FontFamily="{StaticResource AppFont}"
        FontSize="{StaticResource FontSizeMin}">

    <Window.Resources>
        <Style x:Key="CreateStepBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#E0DEDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F9FAFB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CreateStepBtnActive" TargetType="Button" BasedOn="{StaticResource CreateStepBtn}">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1A1A1A"/>
        </Style>
        <Style x:Key="PreviewSectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#C8102E"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A1A1A" Padding="24,16">
            <StackPanel Orientation="Horizontal">
                <controls:FaIcon Icon="plus" IconBrush="White" Width="22" Height="22" Margin="0,0,12,0"/>
                <TextBlock Text="{DynamicResource CreateJob_Title}"
                           Foreground="White" FontSize="{StaticResource FontSizeHeading}"
                           FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#E0DEDD" BorderThickness="0,0,0,1" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnStepInput" Grid.Column="0" Style="{StaticResource CreateStepBtnActive}"
                        Click="BtnStepInput_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="1" FontWeight="Bold" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource CreateJob_Step_Input}"/>
                    </StackPanel>
                </Button>
                <Border Grid.Column="1" Width="40" Height="2" Background="#E0DEDD" VerticalAlignment="Center" Margin="8,0"/>
                <Button x:Name="BtnStepPreview" Grid.Column="2" Style="{StaticResource CreateStepBtn}"
                        Click="BtnStepPreview_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="2" FontWeight="Bold" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource CreateJob_Step_Preview}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" Padding="24,16" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <StackPanel x:Name="PnlInput">
                    <Border Background="White" CornerRadius="8" BorderBrush="#E0DEDD" BorderThickness="1"
                            Padding="20" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource CreateJob_Section_Basic}" Style="{StaticResource PreviewSectionTitle}"/>
                            <TextBlock Text="{DynamicResource CreateJob_Dept}" Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                            <ComboBox x:Name="CmbDept" Margin="0,0,0,14"/>
                            <TextBlock Text="{DynamicResource CreateJob_TitleField}" Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtTitle" Margin="0,0,0,14"
                                     controls:PlaceholderProperties.Text="{DynamicResource Placeholder_JobTitle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="{DynamicResource CreateJob_SalMin}" Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtSalMin" controls:PlaceholderProperties.Text="{DynamicResource Placeholder_SalaryMin}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="{DynamicResource CreateJob_SalMax}" Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtSalMax" controls:PlaceholderProperties.Text="{DynamicResource Placeholder_SalaryMax}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{DynamicResource CreateJob_Count}" Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtCount" BorderBrush="#E0DEDD" Background="White" Text="1"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="8" BorderBrush="#E0DEDD" BorderThickness="1"
                            Padding="20" Margin="0,0,0,14">
                        <StackPanel>
                            <controls:BulletListInput x:Name="ListResponsibilities" Margin="0,0,0,14"/>
                            <controls:BulletListInput x:Name="ListQualifications"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="8" BorderBrush="#E0DEDD" BorderThickness="1"
                            Padding="20" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource CreateJob_Section_Other}" Style="{StaticResource PreviewSectionTitle}"/>
                            <controls:BulletListInput x:Name="ListBenefits" Margin="0,0,0,14"/>
                            <TextBlock Text="{DynamicResource CreateJob_WorkHours}" Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtWorkHours" Margin="0,0,0,14"
                                     controls:PlaceholderProperties.Text="{DynamicResource Placeholder_WorkHours}"/>
                            <TextBlock Text="{DynamicResource CreateJob_WorkLocation}" Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtWorkLocation"
                                     controls:PlaceholderProperties.Text="{DynamicResource Placeholder_WorkLocation}"/>
                        </StackPanel>
                    </Border>

                    <CheckBox x:Name="ChkPublishNow" Content="{DynamicResource CreateJob_PublishNow}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtError" Foreground="#C8102E" Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel x:Name="PnlPreview" Visibility="Collapsed">
                    <Border Background="White" CornerRadius="8" BorderBrush="#E0DEDD" BorderThickness="1"
                            Padding="20" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock x:Name="PreviewDept" Foreground="#6B6B6B" Margin="0,0,0,6"/>
                            <TextBlock x:Name="PreviewTitle" FontSize="{StaticResource FontSizeHeading}"
                                       FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <TextBlock x:Name="PreviewSalary" Foreground="#C8102E" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock x:Name="PreviewPositions" Foreground="#6B6B6B" Margin="0,0,0,16"/>
                            <TextBlock x:Name="PreviewWorkHours" Foreground="#6B6B6B" Margin="0,0,0,4" Visibility="Collapsed"/>
                            <TextBlock x:Name="PreviewWorkLocation" Foreground="#6B6B6B" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <ItemsControl x:Name="PreviewSections">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" BorderBrush="#E0DEDD" BorderThickness="1"
                                        Padding="20" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource PreviewSectionTitle}"/>
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Margin="12,0,0,6" TextWrapping="Wrap"
                                                               FontWeight="Medium"
                                                               Text="{Binding StringFormat=• {0}}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3" Background="White" BorderBrush="#E0DEDD" BorderThickness="0,1,0,0" Padding="24,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Margin="8,0,0,0"
                        Background="#F4F4F2" Foreground="#1A1A1A"
                        BorderBrush="#E0DEDD" BorderThickness="1"
                        Cursor="Hand" Click="BtnCancel_Click">
                    <controls:FaButtonContent Icon="xmark" Label="{DynamicResource Btn_Cancel}"
                        IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <Button x:Name="BtnNext" DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                        Margin="8,0,0,0" Click="BtnNext_Click">
                    <controls:FaButtonContent Icon="chevron-right" Label="{DynamicResource Btn_Next}"
                        IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <Button x:Name="BtnBack" DockPanel.Dock="Right" Style="{StaticResource DarkButton}"
                        Margin="8,0,0,0" Visibility="Collapsed" Click="BtnBack_Click">
                    <controls:FaButtonContent Icon="chevron-left" Label="{DynamicResource Btn_Back}"
                        IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <Button x:Name="BtnSave" DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                        Margin="8,0,0,0" Visibility="Collapsed" Click="BtnSave_Click">
                    <controls:FaButtonContent Icon="plus" Label="{DynamicResource CreateJob_Button}"
                        IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
            </DockPanel>
        </Border>
    </Grid>
</Window>
