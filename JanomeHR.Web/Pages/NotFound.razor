@page "/not-found"
@layout MainLayout
@inject LocaleService Locale
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@Locale.T("NotFound_Title") — @Locale.T("PageTitle_Suffix")</PageTitle>

<div class="container empty-state not-found-page">
    <FaIcon Name="circle-question" Class="empty-icon" />
    <h1>@Locale.T("NotFound_Title")</h1>
    <p>@Locale.T("NotFound_Desc")</p>
    <a href="/" class="text-link" @onclick="GoHome" @onclick:preventDefault>
        <FaIcon Name="arrow-left" Class="inline-icon" /> @Locale.T("NotFound_Back")
    </a>
</div>

@code {
    protected override void OnInitialized() =>
        Locale.Changed += OnLocaleChanged;

    private void GoHome() => Nav.NavigateTo("/");

    private void OnLocaleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Locale.Changed -= OnLocaleChanged;
}
