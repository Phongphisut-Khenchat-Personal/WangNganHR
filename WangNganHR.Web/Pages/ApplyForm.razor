@page "/apply/{JobId}"
@using WangNganHR.Web.Pages

<PageTitle>@Locale.T("Apply_Title") — @Locale.T("PageTitle_Suffix")</PageTitle>

@if (_loading)
{
    <div class="container loading">
        <FaIcon Name="spinner" Class="loading-fa" />
        <p>@Locale.T("Apply_Loading")</p>
    </div>
}
else if (_job is null)
{
    <div class="container empty-state">
        <FaIcon Name="circle-xmark" Class="empty-icon" />
        <p>@Locale.T("Apply_NotFound")</p>
        <a href="/" class="text-link"><FaIcon Name="arrow-left" Class="inline-icon" /> @Locale.T("Apply_BackList")</a>
    </div>
}
else if (_submitted)
{
    <div class="success-screen">
        <div class="success-icon"><FaIcon Name="circle-check" Class="success-fa" /></div>
        <h2>@Locale.T("Apply_Success_Title")</h2>
        <p>@Locale.T("Apply_Success_Desc")</p>
        <div class="ref-code">@_refCode</div>
        <p class="ref-note">@Locale.T("Apply_RefNote")</p>
        <button type="button" class="btn-track" @onclick='() => Nav.NavigateTo("/track")'>
            <FaIcon Name="route" Class="btn-icon" /> @Locale.T("Track_Title")
        </button>
    </div>
}
else
{
    <div class="form-hero">
        <div class="back-btn" @onclick='() => Nav.NavigateTo("/")'>
            <FaIcon Name="arrow-left" Class="inline-icon" /> @Locale.T("Apply_Back")
        </div>
        <h1>@_job.Title</h1>
        @if (_job.Responsibilities.Count > 0)
        {
            <div class="job-requirements">
                <h3>@Locale.T("Job_Responsibilities")</h3>
                <ul class="job-bullet-list">
                    @foreach (var item in _job.Responsibilities)
                    {
                        <li>@item</li>
                    }
                </ul>
            </div>
        }
        @if (_job.Qualifications.Count > 0)
        {
            <div class="job-requirements">
                <h3>@Locale.T("Job_Qualifications")</h3>
                <ul class="job-bullet-list">
                    @foreach (var item in _job.Qualifications)
                    {
                        <li>@item</li>
                    }
                </ul>
            </div>
        }
    </div>

    <div class="container apply-form-container">
        <EditForm Model="_form" OnValidSubmit="HandleSubmit">
            <div class="form-stepper" aria-label="@Locale.F("Apply_StepProgress", _step + 1, 5)">
                @for (var i = 0; i < 5; i++)
                {
                    var index = i;
                    var isActive = _step == index;
                    var isDone = _step > index;
                    <div class="stepper-item @(isActive ? "active" : isDone ? "done" : "")">
                        <div class="stepper-marker">
                            @if (isDone) { <FaIcon Name="circle-check" Class="stepper-check" /> }
                            else { <span class="stepper-num">@(index + 1)</span> }
                        </div>
                        <span class="stepper-label">@GetStepLabel(index)</span>
                    </div>
                    @if (index < 4) { <div class="stepper-line @(isDone ? "done" : "")"></div> }
                }
            </div>
            <p class="stepper-progress">@Locale.F("Apply_StepProgress", _step + 1, 5)</p>

            @* ── Step 1: Personal ── *@
            @if (_step == 0)
            {
                <div class="form-section">
                    <div class="section-title"><FaIcon Name="user" Class="section-icon" /> @Locale.T("Apply_Section_Personal")</div>
                    <div class="form-grid">
                        <div class="field">
                            <label>@Locale.T("Apply_TitlePrefix")</label>
                            <InputSelect @bind-Value="_form.TitlePrefix">
                                <option value="">@Locale.T("Edu_Select")</option>
                                <option value="Mr">@Locale.T("Prefix_Mr")</option>
                                <option value="Mrs">@Locale.T("Prefix_Mrs")</option>
                                <option value="Miss">@Locale.T("Prefix_Miss")</option>
                            </InputSelect>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_Gender")</label>
                            <InputSelect @bind-Value="_form.Gender">
                                <option value="">@Locale.T("Edu_Select")</option>
                                <option value="Male">@Locale.T("Gender_Male")</option>
                                <option value="Female">@Locale.T("Gender_Female")</option>
                                <option value="Other">@Locale.T("Gender_Other")</option>
                            </InputSelect>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_FirstName") <span class="req">*</span></label>
                            <InputText @bind-Value="_form.FirstName" placeholder="@Locale.T("Apply_FirstName")"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_LastName") <span class="req">*</span></label>
                            <InputText @bind-Value="_form.LastName" placeholder="@Locale.T("Apply_LastName")"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_NationalId") <span class="req">*</span></label>
                            <InputText @bind-Value="_form.NationalId" placeholder="XXXXXXXXXXXXX" maxlength="13"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_Birthdate") <span class="req">*</span></label>
                            <InputDate @bind-Value="_form.Birthdate" class="date-input"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_Phone") <span class="req">*</span></label>
                            <InputText @bind-Value="_form.Phone" placeholder="@Locale.T("Apply_PhonePlaceholder")"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_Email")</label>
                            <InputText @bind-Value="_form.Email" placeholder="@Locale.T("Apply_EmailPlaceholder")"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_LineId")</label>
                            <InputText @bind-Value="_form.LineId" placeholder="Line ID"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_Nationality")</label>
                            <InputSelect @bind-Value="_form.NationalityType">
                                <option value="Thai">@Locale.T("Nationality_Thai")</option>
                                <option value="Foreign">@Locale.T("Nationality_Foreign")</option>
                                <option value="MigrantWorker">@Locale.T("Nationality_Migrant")</option>
                            </InputSelect>
                        </div>
                        <div class="field full">
                            <label>@Locale.T("Apply_Address")</label>
                            <InputTextArea @bind-Value="_form.Address" placeholder="@Locale.T("Apply_Address")"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_Province")</label>
                            <InputText @bind-Value="_form.Province"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_District")</label>
                            <InputText @bind-Value="_form.District"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_PostalCode")</label>
                            <InputText @bind-Value="_form.PostalCode" maxlength="5"/>
                        </div>
                        <div class="field full checkbox-field">
                            <label class="checkbox-label">
                                <InputCheckbox Value="_form.SameAsCurrentAddress"
                                               ValueChanged="OnSameAddressChanged"
                                               ValueExpression="() => _form.SameAsCurrentAddress"/>
                                @Locale.T("Apply_SameAddress")
                            </label>
                        </div>
                        @if (!_form.SameAsCurrentAddress)
                        {
                            <div class="field full">
                                <label>@Locale.T("Apply_RegisteredAddress")</label>
                                <InputTextArea @bind-Value="_form.RegisteredAddress"/>
                            </div>
                        }
                    </div>
                    <p class="field-group-label">@Locale.T("Apply_EmergencySection")</p>
                    <div class="form-grid">
                        <div class="field">
                            <label>@Locale.T("Apply_EmergencyName")</label>
                            <InputText @bind-Value="_form.EmergencyContactName"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_EmergencyPhone")</label>
                            <InputText @bind-Value="_form.EmergencyContactPhone"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_EmergencyRelation")</label>
                            <InputText @bind-Value="_form.EmergencyContactRelation"/>
                        </div>
                    </div>
                </div>
            }

            @* ── Step 2: Education ── *@
            else if (_step == 1)
            {
                <div class="form-section">
                    <div class="section-title"><FaIcon Name="graduation-cap" Class="section-icon" /> @Locale.T("Apply_Section_Education")</div>
                    <div class="form-grid">
                        <div class="field">
                            <label>@Locale.T("Apply_Education") <span class="req">*</span></label>
                            <InputSelect @bind-Value="_form.EducationLevel">
                                <option value="">@Locale.T("Edu_Select")</option>
                                <option value="BelowMiddleSchool">@Locale.T("Edu_BelowMiddle")</option>
                                <option value="MiddleSchool">@Locale.T("Edu_Middle")</option>
                                <option value="HighSchool">@Locale.T("Edu_HighSchool")</option>
                                <option value="Vocational">@Locale.T("Edu_Vocational")</option>
                                <option value="HighVocational">@Locale.T("Edu_HighVocational")</option>
                                <option value="Bachelor">@Locale.T("Edu_Bachelor")</option>
                                <option value="Master">@Locale.T("Edu_Master")</option>
                                <option value="Doctor">@Locale.T("Edu_Doctor")</option>
                            </InputSelect>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_Field")</label>
                            <InputText @bind-Value="_form.EducationField"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_SchoolName")</label>
                            <InputText @bind-Value="_form.SchoolName"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_GraduationYear")</label>
                            <InputNumber @bind-Value="_form.GraduationYear"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_Gpa")</label>
                            <InputNumber @bind-Value="_form.Gpa" step="0.01"/>
                        </div>
                    </div>
                    <p class="field-group-label">@Locale.T("Apply_SkillsSection")</p>
                    <div class="form-grid">
                        <div class="field">
                            <label>@Locale.T("Apply_SkillThai")</label>
                            <InputSelect @bind-Value="_form.SkillThai">
                                @foreach (var lvl in new[] { "None", "Basic", "Good", "Fluent" })
                                { <option value="@lvl">@Locale.T($"Skill_{lvl}")</option> }
                            </InputSelect>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_SkillEnglish")</label>
                            <InputSelect @bind-Value="_form.SkillEnglish">
                                @foreach (var lvl in new[] { "None", "Basic", "Good", "Fluent" })
                                { <option value="@lvl">@Locale.T($"Skill_{lvl}")</option> }
                            </InputSelect>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_SkillJapanese")</label>
                            <InputSelect @bind-Value="_form.SkillJapanese">
                                @foreach (var lvl in new[] { "None", "Basic", "Good", "Fluent" })
                                { <option value="@lvl">@Locale.T($"Skill_{lvl}")</option> }
                            </InputSelect>
                        </div>
                        <div class="field full">
                            <label>@Locale.T("Apply_ComputerSkills")</label>
                            <InputText @bind-Value="_form.ComputerSkills" placeholder="Excel, Word..."/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_DriversLicense")</label>
                            <InputSelect @bind-Value="_form.HasDriversLicense">
                                <option value="">@Locale.T("Edu_Select")</option>
                                <option value="true">@Locale.T("Yes")</option>
                                <option value="false">@Locale.T("No")</option>
                            </InputSelect>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_OwnVehicle")</label>
                            <InputSelect @bind-Value="_form.HasOwnVehicle">
                                <option value="">@Locale.T("Edu_Select")</option>
                                <option value="true">@Locale.T("Yes")</option>
                                <option value="false">@Locale.T("No")</option>
                            </InputSelect>
                        </div>
                    </div>
                </div>
            }

            @* ── Step 3: Work Experience ── *@
            else if (_step == 2)
            {
                <div class="form-section">
                    <div class="section-title"><FaIcon Name="briefcase" Class="section-icon" /> @Locale.T("Apply_Section_Work")</div>
                    <div class="form-grid">
                        <div class="field">
                            <label>@Locale.T("Apply_AvailableDate") <span class="req">*</span></label>
                            <InputDate @bind-Value="_form.AvailableDate" class="date-input"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_Experience")</label>
                            <InputNumber @bind-Value="_form.ExperienceYears"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_Salary")</label>
                            <InputNumber @bind-Value="_form.SalaryExpected"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_LastSalary")</label>
                            <InputNumber @bind-Value="_form.LastSalary"/>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_ShiftWork") <span class="req">*</span></label>
                            <InputSelect @bind-Value="_form.WillingShiftWork">
                                <option value="">@Locale.T("Edu_Select")</option>
                                <option value="true">@Locale.T("Yes")</option>
                                <option value="false">@Locale.T("No")</option>
                            </InputSelect>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_Overtime") <span class="req">*</span></label>
                            <InputSelect @bind-Value="_form.WillingOvertime">
                                <option value="">@Locale.T("Edu_Select")</option>
                                <option value="true">@Locale.T("Yes")</option>
                                <option value="false">@Locale.T("No")</option>
                            </InputSelect>
                        </div>
                        <div class="field">
                            <label>@Locale.T("Apply_Relocate")</label>
                            <InputSelect @bind-Value="_form.WillingRelocate">
                                <option value="">@Locale.T("Edu_Select")</option>
                                <option value="true">@Locale.T("Yes")</option>
                                <option value="false">@Locale.T("No")</option>
                            </InputSelect>
                        </div>
                        <div class="field full checkbox-field">
                            <label class="checkbox-label">
                                <InputCheckbox Value="_form.IsFreshGraduate"
                                               ValueChanged="OnFreshGraduateChanged"
                                               ValueExpression="() => _form.IsFreshGraduate"/>
                                @Locale.T("Apply_FreshGraduate")
                            </label>
                        </div>
                    </div>

                    @if (!_form.IsFreshGraduate)
                    {
                        <p class="field-group-label">@Locale.T("Apply_WorkHistory")</p>
                        @for (var wi = 0; wi < _form.WorkExperiences.Count; wi++)
                        {
                            var idx = wi;
                            var w = _form.WorkExperiences[idx];
                            <div class="work-exp-card">
                                <div class="work-exp-head">
                                    <span>@Locale.F("Apply_WorkItem", idx + 1)</span>
                                    @if (_form.WorkExperiences.Count > 1)
                                    {
                                        <button type="button" class="btn-icon-only" @onclick="() => RemoveWorkExperience(idx)">
                                            <FaIcon Name="trash"/>
                                        </button>
                                    }
                                </div>
                                <div class="form-grid">
                                    <div class="field">
                                        <label>@Locale.T("Apply_Company") <span class="req">*</span></label>
                                        <InputText @bind-Value="w.CompanyName"/>
                                    </div>
                                    <div class="field">
                                        <label>@Locale.T("Apply_Position") <span class="req">*</span></label>
                                        <InputText @bind-Value="w.Position"/>
                                    </div>
                                    <div class="field">
                                        <label>@Locale.T("Apply_StartDate")</label>
                                        <InputDate @bind-Value="w.StartDate" class="date-input"/>
                                    </div>
                                    <div class="field">
                                        <label>@Locale.T("Apply_EndDate")</label>
                                        <InputDate @bind-Value="w.EndDate" class="date-input"/>
                                    </div>
                                    <div class="field full">
                                        <label>@Locale.T("Apply_Responsibilities")</label>
                                        <InputTextArea @bind-Value="w.Responsibilities"/>
                                    </div>
                                    <div class="field">
                                        <label>@Locale.T("Apply_LeaveReason")</label>
                                        <InputText @bind-Value="w.ReasonForLeaving"/>
                                    </div>
                                    <div class="field">
                                        <label>@Locale.T("Apply_JobSalary")</label>
                                        <InputNumber @bind-Value="w.Salary"/>
                                    </div>
                                </div>
                            </div>
                        }
                        <button type="button" class="btn-add-row" @onclick="AddWorkExperience">
                            <FaIcon Name="plus" Class="btn-icon"/> @Locale.T("Apply_AddWork")
                        </button>
                    }
                </div>
            }

            @* ── Step 4: Documents ── *@
            else if (_step == 3)
            {
                <div class="form-section">
                    <div class="section-title"><FaIcon Name="file" Class="section-icon" /> @Locale.T("Apply_Section_Documents")</div>
                    <p class="review-note">@Locale.T("Apply_DocumentsNote")</p>

                    <div class="upload-box">
                        <label class="upload-label">@Locale.T("Apply_Doc_Resume")</label>
                        <InputFile OnChange="OnResumeSelected" accept=".pdf,.doc,.docx" class="file-input"/>
                        @if (_resumeFile is not null)
                        {
                            <div class="file-chip">
                                <FaIcon Name="file" Class="inline-icon"/> @_resumeFile.Name
                                <button type="button" class="file-remove" @onclick="ClearResume"><FaIcon Name="xmark"/></button>
                            </div>
                        }
                    </div>
                    <div class="upload-box">
                        <label class="upload-label">@Locale.T("Apply_Doc_Photo")</label>
                        <InputFile OnChange="OnPhotoSelected" accept=".jpg,.jpeg,.png" class="file-input"/>
                        @if (_photoFile is not null)
                        {
                            <div class="file-chip">
                                <FaIcon Name="file" Class="inline-icon"/> @_photoFile.Name
                                <button type="button" class="file-remove" @onclick="ClearPhoto"><FaIcon Name="xmark"/></button>
                            </div>
                        }
                    </div>
                    <div class="upload-box">
                        <label class="upload-label">@Locale.T("Apply_Doc_Certificate")</label>
                        <InputFile OnChange="OnCertSelected" accept=".pdf,.jpg,.jpeg,.png" multiple class="file-input"/>
                        @foreach (var f in _certFiles)
                        {
                            <div class="file-chip">
                                <FaIcon Name="file" Class="inline-icon"/> @f.Name
                                <button type="button" class="file-remove" @onclick="() => ClearCert(f)"><FaIcon Name="xmark"/></button>
                            </div>
                        }
                    </div>
                </div>
            }

            @* ── Step 5: Review + PDPA ── *@
            else
            {
                <div class="form-section review-section">
                    <div class="section-title"><FaIcon Name="circle-check" Class="section-icon" /> @Locale.T("Apply_Step_Review")</div>
                    <p class="review-note">@Locale.T("Apply_Review_Note")</p>

                    @foreach (var block in _reviewBlocks)
                    {
                        <h3 class="review-block-title">@block.Title</h3>
                        <dl class="review-list">
                            @foreach (var field in block.Fields)
                            {
                                <dt>@field.Label</dt>
                                <dd>@field.Value</dd>
                            }
                        </dl>
                    }

                    <div class="field" style="margin-top: 20px;">
                        <label>@Locale.T("Apply_ReferralSource")</label>
                        <InputSelect @bind-Value="_form.ReferralSource">
                            <option value="">@Locale.T("Edu_Select")</option>
                            <option value="JobBoard">@Locale.T("Referral_JobBoard")</option>
                            <option value="Social">@Locale.T("Referral_Social")</option>
                            <option value="Friend">@Locale.T("Referral_Friend")</option>
                            <option value="Company">@Locale.T("Referral_Company")</option>
                            <option value="QR">@Locale.T("Referral_QR")</option>
                            <option value="WalkIn">@Locale.T("Referral_WalkIn")</option>
                            <option value="Other">@Locale.T("Referral_Other")</option>
                        </InputSelect>
                    </div>

                    <div class="pdpa-box">
                        <h3 class="pdpa-title">@Locale.T("Apply_PDPA_Title")</h3>
                        <p class="pdpa-text">@Locale.T("Apply_PDPA_Text")</p>
                        <label class="checkbox-label pdpa-check">
                            <InputCheckbox @bind-Value="_form.PdpaConsented"/>
                            <span>@Locale.T("Apply_PDPA_Agree") <span class="req">*</span></span>
                        </label>
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="error-box"><FaIcon Name="circle-xmark" Class="inline-icon" /> @_error</div>
            }

            <div class="stepper-actions">
                @if (_step > 0)
                {
                    <button type="button" class="btn-step btn-step-back" @onclick="PrevStep" disabled="@_submitting">
                        <FaIcon Name="chevron-left" Class="btn-icon"/> @Locale.T("Apply_StepPrev")
                    </button>
                }
                @if (_step < 4)
                {
                    <button type="button" class="btn-step btn-step-next" @onclick="NextStep">
                        @Locale.T("Apply_Next") <FaIcon Name="chevron-right" Class="btn-icon"/>
                    </button>
                }
                else
                {
                    <button type="submit" class="btn-submit" disabled="@_submitting">
                        @if (_submitting)
                        { <FaIcon Name="spinner" Class="btn-icon"/> <text>@Locale.T("Apply_Submitting")</text> }
                        else
                        { <text>@Locale.T("Apply_Submit")</text> <FaIcon Name="arrow-right" Class="btn-icon"/> }
                    </button>
                }
            </div>
        </EditForm>
    </div>
}
