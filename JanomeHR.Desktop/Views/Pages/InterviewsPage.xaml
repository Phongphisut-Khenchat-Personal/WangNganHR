<Page x:Class="JanomeHR.Desktop.Views.Pages.InterviewsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F4F2">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Date Navigator -->
        <Border Grid.Row="0" Background="White" CornerRadius="6"
                BorderBrush="#E0DEDD" BorderThickness="1"
                Padding="16,12" Margin="0,0,0,12">
            <DockPanel>
                <Button Content="◀" DockPanel.Dock="Left"
                        Width="36" Height="36"
                        Background="Transparent" BorderBrush="#E0DEDD"
                        FontSize="14" Cursor="Hand"
                        Click="BtnPrevDay_Click"/>
                <Button Content="▶" DockPanel.Dock="Right"
                        Width="36" Height="36"
                        Background="Transparent" BorderBrush="#E0DEDD"
                        FontSize="14" Cursor="Hand"
                        Click="BtnNextDay_Click"/>
                <Button Content="วันนี้" DockPanel.Dock="Right"
                        Padding="12,0" Height="36" Margin="8,0"
                        Background="#1A1A1A" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnToday_Click"/>
                <TextBlock x:Name="TxtDate"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16" FontWeight="SemiBold"/>
            </DockPanel>
        </Border>

        <!-- Stats -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="White" CornerRadius="6"
                    BorderBrush="#E0DEDD" BorderThickness="1"
                    Margin="0,0,8,0" Padding="14,10">
                <StackPanel>
                    <TextBlock x:Name="TxtTotalToday" Text="0"
                               FontSize="24" FontWeight="SemiBold"
                               Foreground="#1D4ED8"/>
                    <TextBlock Text="นัดวันนี้ทั้งหมด"
                               FontSize="11" Foreground="#888"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="White" CornerRadius="6"
                    BorderBrush="#E0DEDD" BorderThickness="1"
                    Margin="0,0,8,0" Padding="14,10">
                <StackPanel>
                    <TextBlock x:Name="TxtOnline" Text="0"
                               FontSize="24" FontWeight="SemiBold"
                               Foreground="#1A7A4A"/>
                    <TextBlock Text="Online"
                               FontSize="11" Foreground="#888"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="White" CornerRadius="6"
                    BorderBrush="#E0DEDD" BorderThickness="1"
                    Padding="14,10">
                <StackPanel>
                    <TextBlock x:Name="TxtOnsite" Text="0"
                               FontSize="24" FontWeight="SemiBold"
                               Foreground="#B45309"/>
                    <TextBlock Text="Onsite"
                               FontSize="11" Foreground="#888"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Interview List -->
        <Border Grid.Row="2" Background="White" CornerRadius="6"
                BorderBrush="#E0DEDD" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Border Grid.Row="0" Background="#F4F4F2"
                        BorderBrush="#E0DEDD" BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="เวลา"
                                   FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                        <TextBlock Grid.Column="1" Text="ผู้สมัคร"
                                   FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                        <TextBlock Grid.Column="2" Text="ตำแหน่ง"
                                   FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                        <TextBlock Grid.Column="3" Text="ผู้สัมภาษณ์"
                                   FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                        <TextBlock Grid.Column="4" Text="รูปแบบ"
                                   FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                        <TextBlock Grid.Column="5" Text="สถานะ"
                                   FontSize="11" FontWeight="SemiBold" Foreground="#888"/>
                    </Grid>
                </Border>

                <!-- Rows -->
                <ScrollViewer Grid.Row="1">
                    <ItemsControl x:Name="LstInterviews">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F0EEEB"
                                        BorderThickness="0,0,0,1"
                                        Padding="16,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding TimeText}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#C8102E"
                                                   VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ApplicantName}"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding DurationText}"
                                                       FontSize="11" Foreground="#888"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding JobPostingTitle}"
                                                   FontSize="13" Foreground="#555"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding InterviewerName}"
                                                   FontSize="12" Foreground="#555"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Column="4"
                                                Background="{Binding TypeColor}"
                                                CornerRadius="10" Padding="8,3"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TypeText}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{Binding TypeTextColor}"/>
                                        </Border>
                                        <Border Grid.Column="5"
                                                Background="{Binding StatusColor}"
                                                CornerRadius="10" Padding="8,3"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusText}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{Binding StatusTextColor}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty State -->
                <TextBlock x:Name="TxtEmpty"
                           Grid.Row="1"
                           Text="ไม่มีนัดสัมภาษณ์ในวันนี้"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="14" Foreground="#888"
                           Margin="0,40"/>
            </Grid>
        </Border>
    </Grid>
</Page>