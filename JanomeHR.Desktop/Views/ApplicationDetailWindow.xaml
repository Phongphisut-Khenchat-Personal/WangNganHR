<Window x:Class="JanomeHR.Desktop.Views.ApplicationDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="รายละเอียดผู้สมัคร"
        Height="680" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="#F4F4F2"
        FontFamily="{StaticResource AppFont}"
        FontSize="{StaticResource FontSizeMin}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A1A1A" Padding="24,20">
            <StackPanel>
                <TextBlock x:Name="TxtRefCode"
                           Foreground="#C8102E" FontFamily="Consolas"/>
                <TextBlock x:Name="TxtName"
                           Foreground="White" FontSize="{StaticResource FontSizeTitle}"
                           FontWeight="SemiBold" Margin="0,6,0,0"/>
                <TextBlock x:Name="TxtPosition" Foreground="#AAAAAA" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="24,20">
            <StackPanel>

                <Border Background="White" CornerRadius="8"
                        BorderBrush="#E0DEDD" BorderThickness="1"
                        Padding="20" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="เบอร์โทรศัพท์" Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtPhone" FontWeight="Medium"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,16">
                            <TextBlock Text="อีเมล" Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtEmail" FontWeight="Medium"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="การศึกษา" Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtEducation" FontWeight="Medium"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,16">
                            <TextBlock Text="ประสบการณ์" Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtExperience" FontWeight="Medium"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="เงินเดือนที่คาดหวัง" Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtSalary" FontWeight="Medium"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,16">
                            <TextBlock Text="เริ่มงานได้" Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtAvailable" FontWeight="Medium"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="0">
                            <TextBlock Text="สถานะปัจจุบัน" Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtStatus" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="1">
                            <TextBlock Text="ช่องทาง" Style="{StaticResource LabelCaption}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtSource" FontWeight="Medium"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="White" CornerRadius="8"
                        BorderBrush="#E0DEDD" BorderThickness="1"
                        Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="อัปเดตสถานะ"
                                   FontWeight="SemiBold" Foreground="#C8102E"
                                   Margin="0,0,0,16"/>
                        <TextBlock Text="สถานะใหม่" Style="{StaticResource LabelCaption}" Margin="0,0,0,8"/>
                        <ComboBox x:Name="CmbNewStatus" Margin="0,0,0,16">
                            <ComboBoxItem Content="ใหม่" Tag="New"/>
                            <ComboBoxItem Content="กำลังพิจารณา" Tag="Review"/>
                            <ComboBoxItem Content="นัดสัมภาษณ์" Tag="Interview"/>
                            <ComboBoxItem Content="ผ่านการพิจารณา" Tag="Pass"/>
                            <ComboBoxItem Content="ไม่ผ่าน" Tag="Fail"/>
                        </ComboBox>
                        <TextBlock Text="หมายเหตุ" Style="{StaticResource LabelCaption}" Margin="0,0,0,8"/>
                        <TextBox x:Name="TxtNote"
                                 BorderBrush="#E0DEDD"
                                 MinHeight="88" TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,16"/>
                        <Button Content="บันทึกสถานะ"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left"
                                Click="BtnSaveStatus_Click"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="8"
                        BorderBrush="#E0DEDD" BorderThickness="1"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="ประวัติโน้ต"
                                   Style="{StaticResource LabelCaption}"
                                   Margin="0,0,0,16"/>
                        <ItemsControl x:Name="LstNotes">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F0EEEB" BorderThickness="0,0,0,1"
                                            Padding="0,12">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,6">
                                                <TextBlock Text="{Binding CreatedByName}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding CreatedAtText}"
                                                           Foreground="#6B6B6B"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <TextBlock Text="{Binding Content}"
                                                       TextWrapping="Wrap"
                                                       LineHeight="24"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White"
                BorderBrush="#E0DEDD" BorderThickness="0,1,0,0"
                Padding="24,16">
            <Button Content="ปิด" DockPanel.Dock="Right"
                    Style="{StaticResource DarkButton}"
                    HorizontalAlignment="Right"
                    Click="BtnClose_Click"/>
        </Border>
    </Grid>
</Window>
