<Window x:Class="JanomeHR.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:JanomeHR.Desktop.Controls"
        Title="{DynamicResource Login_Title}"
        Height="580" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F4F4F2"
        FontFamily="{StaticResource AppFont}"
        FontSize="{StaticResource FontSizeMin}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="150"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A1A1A">
            <StackPanel VerticalAlignment="Center" Margin="36,0">
                <Border Background="#C8102E" HorizontalAlignment="Left"
                        Padding="12,6" Margin="0,0,0,10">
                    <TextBlock Text="JANOME" Foreground="White"
                               FontSize="{StaticResource FontSizeMin}" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="{DynamicResource Brand_Recruitment}" Foreground="#AAAAAA"/>
                <TextBlock Text="{DynamicResource Login_Heading}"
                           Foreground="White" FontSize="{StaticResource FontSizeTitle}"
                           FontWeight="SemiBold" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="36,0" VerticalAlignment="Center">
            <TextBlock Text="{DynamicResource Login_Username}"
                       Style="{StaticResource LabelCaption}" Margin="0,0,0,8"/>
            <TextBox x:Name="TxtUsername" KeyDown="OnKeyDown"
                     controls:PlaceholderProperties.Text="{DynamicResource Placeholder_Username}"/>

            <TextBlock Text="{DynamicResource Login_Password}"
                       Style="{StaticResource LabelCaption}" Margin="0,16,0,8"/>
            <PasswordBox x:Name="TxtPassword" KeyDown="OnKeyDown"/>

            <TextBlock x:Name="TxtError"
                       Foreground="#C8102E"
                       Margin="0,12,0,0" Visibility="Collapsed"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="36,0,36,24">
            <Button x:Name="BtnLogin"
                    Style="{StaticResource PrimaryButton}"
                    MinHeight="44"
                    Click="BtnLogin_Click">
                <controls:FaButtonContent Icon="sign-in"
                    Label="{DynamicResource Login_Button}"
                    IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
            </Button>
            <Button x:Name="BtnSettings"
                    HorizontalAlignment="Stretch"
                    MinHeight="44"
                    Margin="0,12,0,0"
                    Background="White"
                    Foreground="#1A1A1A"
                    BorderBrush="#E0DEDD"
                    BorderThickness="1"
                    Click="BtnSettings_Click">
                <controls:FaButtonContent Icon="gear"
                    Label="{DynamicResource Btn_Settings}"
                    IconBrush="#1A1A1A"/>
                <Button.ContextMenu>
                    <ContextMenu x:Name="LanguageMenu"/>
                </Button.ContextMenu>
            </Button>
            <TextBlock Text="{DynamicResource Footer_Login}"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,0" Foreground="#888888"/>
        </StackPanel>
    </Grid>
</Window>
