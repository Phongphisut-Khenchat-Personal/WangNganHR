@page "/"
@inject ApiService Api
@inject NavigationManager Nav
@inject LocaleService Locale
@implements IDisposable

<PageTitle>@Locale.T("Hero_Title") — @Locale.T("PageTitle_Suffix")</PageTitle>

<div class="hero">
    <div class="hero-content">
        <div class="hero-badge">
            <FaIcon Name="users" Class="hero-badge-icon" />
            @Locale.T("Hero_Badge")
        </div>
        <h1>@Locale.T("Hero_Title")<br/>@Locale.T("Hero_Subtitle")</h1>
        <p>
            <FaIcon Name="qrcode" Class="hero-line-icon" />
            @Locale.T("Hero_Desc")
        </p>
    </div>
</div>

<div class="container">
    @if (_loading)
    {
        <div class="loading">
            <FaIcon Name="spinner" Class="loading-fa" />
            <p>@Locale.T("Loading")</p>
        </div>
    }
    else if (!_jobs.Any())
    {
        <div class="empty">
            <FaIcon Name="briefcase" Class="empty-icon" />
            <p>@Locale.T("Empty_Jobs")</p>
        </div>
    }
    else
    {
        <div class="jobs-grid">
            @foreach (var job in _jobs)
            {
                <div class="job-card" @onclick='() => Nav.NavigateTo($"/job/{job.Id}")'>
                    <div class="job-dept">
                        <FaIcon Name="building" Class="job-meta-icon" />
                        @job.DepartmentName
                    </div>
                    <h2 class="job-title">@job.Title</h2>
                    @if (job.Responsibilities.Count > 0)
                    {
                        <ul class="job-desc-list">
                            @foreach (var item in job.Responsibilities.Take(3))
                            {
                                <li>@item</li>
                            }
                        </ul>
                        @if (job.Responsibilities.Count > 3)
                        {
                            <p class="job-see-more">@Locale.T("Job_SeeMore")</p>
                        }
                    }
                    <div class="job-meta">
                        @if (job.SalaryMin.HasValue)
                        {
                            <span class="salary">
                                <FaIcon Name="money" Class="job-meta-icon" />
                                ฿@job.SalaryMin.Value.ToString("N0")
                                @if (job.SalaryMax.HasValue)
                                { <text> – ฿@job.SalaryMax.Value.ToString("N0")</text> }
                            </span>
                        }
                        <span class="positions">
                            <FaIcon Name="users" Class="job-meta-icon" />
                            @Locale.F("Job_Positions", job.PositionsCount)
                        </span>
                    </div>
                    <button type="button" class="btn-apply" @onclick:stopPropagation='true'
                            @onclick='() => Nav.NavigateTo($"/job/{job.Id}")'>
                        @Locale.T("Job_SeeDetail") <FaIcon Name="arrow-right" Class="btn-icon" />
                    </button>
                </div>
            }
        </div>
    }

    <div class="track-section">
        <p>
            @Locale.T("Track_Already")
            <a href="/track">
                <FaIcon Name="route" Class="inline-icon" />
                @Locale.T("Track_Link")
            </a>
        </p>
    </div>
</div>

@code {
    private List<JobPostingItem> _jobs = [];
    private bool _loading = true;

    protected override void OnInitialized() =>
        Locale.Changed += OnLocaleChanged;

    protected override async Task OnInitializedAsync()
    {
        try { _jobs = await Api.GetActiveJobsAsync(); }
        finally { _loading = false; }
    }

    private void OnLocaleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Locale.Changed -= OnLocaleChanged;
}
